<!DOCTYPE html>
<html>
<head>
    <title>West End Office Intelligence</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', Arial, sans-serif; background: #060d18; color: #e5e7eb; min-height: 100vh; overflow-x: hidden; }

        /* NAV */
        .nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 60px; border-bottom: 1px solid rgba(255,255,255,0.05); position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(6,13,24,0.9); backdrop-filter: blur(12px); }
        .nav-logo { font-size: 15px; font-weight: 700; color: #fff; }
        .nav-logo span { color: #3b82f6; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .nav-link { font-size: 13px; color: #64748b; text-decoration: none; transition: color 0.2s; }
        .nav-link:hover { color: #e2e8f0; }
        .nav-btn { background: #3b82f6; color: white; padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background 0.2s; }
        .nav-btn:hover { background: #2563eb; }

        /* HERO */
        .hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 120px 40px 80px; position: relative; overflow: hidden; }
        .hero-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(59,130,246,0.12) 0%, transparent 70%), radial-gradient(ellipse 60% 40% at 80% 50%, rgba(168,85,247,0.06) 0%, transparent 60%); pointer-events: none; }
        .hero-grid { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px; pointer-events: none; }
        .hero-content { position: relative; max-width: 800px; margin: auto; }
        .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); color: #60a5fa; padding: 6px 16px; border-radius: 999px; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 28px; }
        .hero-eyebrow-dot { width: 6px; height: 6px; background: #3b82f6; border-radius: 50%; animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
        .hero h1 { font-size: 58px; font-weight: 800; line-height: 1.1; margin-bottom: 24px; letter-spacing: -1.5px; }
        .hero h1 .line1 { display: block; background: linear-gradient(135deg, #ffffff 0%, #e2e8f0 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero h1 .line2 { display: block; background: linear-gradient(135deg, #3b82f6 0%, #a855f7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero-sub { font-size: 17px; color: #64748b; line-height: 1.8; max-width: 560px; margin: 0 auto 40px; }
        .hero-buttons { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
        .btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; padding: 14px 32px; border-radius: 12px; font-size: 15px; font-weight: 700; text-decoration: none; transition: all 0.2s; box-shadow: 0 8px 24px rgba(59,130,246,0.3); display: inline-flex; align-items: center; gap: 8px; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(59,130,246,0.4); }
        .btn-secondary { background: rgba(255,255,255,0.05); color: #94a3b8; padding: 14px 32px; border-radius: 12px; font-size: 15px; font-weight: 600; text-decoration: none; border: 1px solid rgba(255,255,255,0.08); transition: all 0.2s; }
        .btn-secondary:hover { background: rgba(255,255,255,0.08); color: #e2e8f0; }

        /* STATS BAR */
        .stats-bar { background: rgba(255,255,255,0.02); border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 24px 60px; }
        .stats-inner { max-width: 1000px; margin: auto; display: flex; align-items: center; justify-content: space-around; gap: 20px; flex-wrap: wrap; }
        .stat-item { text-align: center; }
        .stat-val { font-size: 28px; font-weight: 800; color: #f1f5f9; }
        .stat-val span { color: #3b82f6; }
        .stat-label { font-size: 11px; color: #475569; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
        .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.06); }

        /* FEATURES */
        .features { padding: 100px 60px; max-width: 1200px; margin: auto; }
        .section-eyebrow { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: #3b82f6; margin-bottom: 16px; text-align: center; }
        .section-title { font-size: 36px; font-weight: 800; text-align: center; color: #f1f5f9; margin-bottom: 14px; letter-spacing: -0.5px; }
        .section-sub { font-size: 15px; color: #64748b; text-align: center; max-width: 500px; margin: 0 auto 60px; line-height: 1.8; }
        .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .feature-card { background: #0b1527; border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 32px; position: relative; overflow: hidden; transition: border-color 0.2s, transform 0.2s; }
        .feature-card:hover { border-color: rgba(59,130,246,0.2); transform: translateY(-3px); }
        .feature-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; opacity: 0; transition: opacity 0.2s; }
        .feature-card:hover::before { opacity: 1; }
        .feature-card.blue::before { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
        .feature-card.purple::before { background: linear-gradient(90deg, #a855f7, #c084fc); }
        .feature-card.green::before { background: linear-gradient(90deg, #22c55e, #4ade80); }
        .feature-card.cyan::before { background: linear-gradient(90deg, #0ea5e9, #38bdf8); }
        .feature-card.amber::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
        .feature-card.rose::before { background: linear-gradient(90deg, #f43f5e, #fb7185); }
        .feature-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 20px; }
        .icon-blue { background: rgba(59,130,246,0.12); }
        .icon-purple { background: rgba(168,85,247,0.12); }
        .icon-green { background: rgba(34,197,94,0.12); }
        .icon-cyan { background: rgba(14,165,233,0.12); }
        .icon-amber { background: rgba(245,158,11,0.12); }
        .icon-rose { background: rgba(244,63,94,0.12); }
        .feature-title { font-size: 16px; font-weight: 700; color: #f1f5f9; margin-bottom: 10px; }
        .feature-text { font-size: 13px; color: #64748b; line-height: 1.8; }

        /* DASHBOARD PREVIEW */
        .preview-section { padding: 0 60px 100px; max-width: 1200px; margin: auto; }
        .preview-card { background: #0b1527; border: 1px solid rgba(255,255,255,0.06); border-radius: 24px; padding: 32px; position: relative; overflow: hidden; }
        .preview-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), rgba(168,85,247,0.4), transparent); }
        .preview-inner { background: #060d18; border-radius: 14px; padding: 24px; border: 1px solid rgba(255,255,255,0.04); }
        .preview-topbar { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
        .preview-dot { width: 10px; height: 10px; border-radius: 50%; }
        .preview-title-bar { flex: 1; height: 8px; background: rgba(255,255,255,0.04); border-radius: 4px; margin-left: 8px; }
        .preview-kpis { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-bottom: 16px; }
        .preview-kpi { background: #0b1527; border: 1px solid rgba(255,255,255,0.04); border-radius: 10px; padding: 14px; }
        .preview-kpi-label { height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; width: 60%; margin-bottom: 10px; }
        .preview-kpi-val { height: 20px; border-radius: 4px; width: 70%; }
        .preview-charts { display: grid; grid-template-columns: 1.6fr 1fr; gap: 10px; }
        .preview-chart { background: #0b1527; border: 1px solid rgba(255,255,255,0.04); border-radius: 10px; padding: 16px; height: 120px; position: relative; overflow: hidden; }
        .preview-chart-line { position: absolute; bottom: 20px; left: 16px; right: 16px; height: 60px; }
        .preview-bars { display: flex; align-items: flex-end; gap: 6px; height: 100%; }
        .preview-bar { flex: 1; border-radius: 4px 4px 0 0; }

        /* DATA SOURCES */
        .sources { padding: 60px; background: rgba(255,255,255,0.01); border-top: 1px solid rgba(255,255,255,0.04); }
        .sources-inner { max-width: 900px; margin: auto; text-align: center; }
        .sources-label { font-size: 11px; color: #334155; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 24px; }
        .sources-badges { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
        .source-badge { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); color: #475569; padding: 8px 18px; border-radius: 8px; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; }

        /* CTA */
        .cta { padding: 100px 60px; text-align: center; position: relative; overflow: hidden; }
        .cta-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(59,130,246,0.08) 0%, transparent 70%); pointer-events: none; }
        .cta-content { position: relative; max-width: 600px; margin: auto; }
        .cta h2 { font-size: 40px; font-weight: 800; color: #f1f5f9; margin-bottom: 16px; letter-spacing: -0.5px; line-height: 1.2; }
        .cta p { font-size: 15px; color: #64748b; margin-bottom: 36px; line-height: 1.8; }

        /* FOOTER */
        .footer { border-top: 1px solid rgba(255,255,255,0.05); padding: 32px 60px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
        .footer-left { font-size: 12px; color: #1e293b; }
        .footer-left strong { color: #334155; }
        .footer-right { display: flex; align-items: center; gap: 10px; }
        .footer-badge { font-size: 11px; padding: 4px 12px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.06); color: #1e293b; }
        .footer-badge-claude { background: rgba(168,85,247,0.08); border-color: rgba(168,85,247,0.15); color: #6d28d9; font-weight: 600; }

        @media (max-width: 900px) {
            .nav { padding: 16px 24px; }
            .hero { padding: 100px 24px 60px; }
            .hero h1 { font-size: 36px; }
            .stats-bar { padding: 24px; }
            .stat-divider { display: none; }
            .features { padding: 60px 24px; }
            .features-grid { grid-template-columns: 1fr; }
            .preview-section { padding: 0 24px 60px; }
            .preview-kpis { grid-template-columns: repeat(2, 1fr); }
            .preview-charts { grid-template-columns: 1fr; }
            .sources { padding: 40px 24px; }
            .cta { padding: 60px 24px; }
            .footer { padding: 24px; flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
    <div class="nav-logo">West End <span>Office Intelligence</span></div>
    <div class="nav-right">
        <a href="dashboard.html" class="nav-link">Dashboard</a>
        <a href="dashboard.html" class="nav-btn">Get Access →</a>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-content">
        <div class="hero-eyebrow">
            <div class="hero-eyebrow-dot"></div>
            Central London · Live Market Intelligence
        </div>
        <h1>
            <span class="line1">Institutional-Grade</span>
            <span class="line2">Office Analytics</span>
        </h1>
        <p class="hero-sub">
            AI-powered leasing intelligence, vacancy forecasting and market commentary across 8 Central London office submarkets. Updated in real time.
        </p>
        <div class="hero-buttons">
            <a href="dashboard.html" class="btn-primary">
                Launch Dashboard →
            </a>
            <a href="#features" class="btn-secondary">
                See Features
            </a>
        </div>
    </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
    <div class="stats-inner">
        <div class="stat-item">
            <div class="stat-val">8<span>+</span></div>
            <div class="stat-label">Submarkets Tracked</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-val">11<span>Q</span></div>
            <div class="stat-label">Quarters of Data</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-val">AI<span>✦</span></div>
            <div class="stat-label">Claude-Powered</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-val">Live</div>
            <div class="stat-label">Web Data Feed</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-val">PDF</div>
            <div class="stat-label">Report Export</div>
        </div>
    </div>
</div>

<!-- FEATURES -->
<section class="features" id="features">
    <div class="section-eyebrow">Platform Features</div>
    <div class="section-title">Everything you need to track the West End</div>
    <div class="section-sub">Built for property professionals who need institutional-quality data without the institutional price tag.</div>

    <div class="features-grid">
        <div class="feature-card blue">
            <div class="feature-icon icon-blue">📊</div>
            <div class="feature-title">AI Vacancy Forecasting</div>
            <div class="feature-text">Machine learning model trained on historical rent, take-up and vacancy data to forecast future availability across each submarket.</div>
        </div>
        <div class="feature-card purple">
            <div class="feature-icon icon-purple">✦</div>
            <div class="feature-title">Claude Market Commentary</div>
            <div class="feature-text">Every submarket gets a freshly generated research note written by Claude in the style of a Savills or CBRE analyst — not a template.</div>
        </div>
        <div class="feature-card cyan">
            <div class="feature-icon icon-cyan">⚡</div>
            <div class="feature-title">Live Web Data Feed</div>
            <div class="feature-text">Claude searches the web in real time to pull the latest published figures from Savills, CBRE, Colliers and Knight Frank quarterly reports.</div>
        </div>
        <div class="feature-card green">
            <div class="feature-icon icon-green">🗺</div>
            <div class="feature-title">Submarket Schematic</div>
            <div class="feature-text">Interactive Central London zone map colour-coded by vacancy rate or prime rent. Click any submarket to load its full analytics instantly.</div>
        </div>
        <div class="feature-card amber">
            <div class="feature-icon icon-amber">⬇</div>
            <div class="feature-title">PDF Research Reports</div>
            <div class="feature-text">One-click download of a professionally formatted submarket research note with KPIs, data table and AI commentary — ready to share.</div>
        </div>
        <div class="feature-card rose">
            <div class="feature-icon icon-rose">📈</div>
            <div class="feature-title">Trend Analytics</div>
            <div class="feature-text">Quarterly vacancy vs rent trend charts, take-up momentum bars and a full cross-submarket comparison — all driven by live data.</div>
        </div>
    </div>
</section>

<!-- DASHBOARD PREVIEW -->
<section class="preview-section">
    <div class="section-eyebrow" style="text-align:center;margin-bottom:16px;">Platform Preview</div>
    <div class="section-title" style="margin-bottom:40px;">Built for the way you work</div>
    <div class="preview-card">
        <div class="preview-inner">
            <div class="preview-topbar">
                <div class="preview-dot" style="background:#ef4444"></div>
                <div class="preview-dot" style="background:#f59e0b"></div>
                <div class="preview-dot" style="background:#22c55e"></div>
                <div class="preview-title-bar"></div>
            </div>

            <!-- Mock KPI row -->
            <div class="preview-kpis">
                <div class="preview-kpi">
                    <div class="preview-kpi-label"></div>
                    <div class="preview-kpi-val" style="background:rgba(59,130,246,0.3)"></div>
                </div>
                <div class="preview-kpi">
                    <div class="preview-kpi-label"></div>
                    <div class="preview-kpi-val" style="background:rgba(34,197,94,0.3)"></div>
                </div>
                <div class="preview-kpi">
                    <div class="preview-kpi-label"></div>
                    <div class="preview-kpi-val" style="background:rgba(168,85,247,0.3)"></div>
                </div>
                <div class="preview-kpi">
                    <div class="preview-kpi-label"></div>
                    <div class="preview-kpi-val" style="background:rgba(245,158,11,0.3)"></div>
                </div>
                <div class="preview-kpi">
                    <div class="preview-kpi-label"></div>
                    <div class="preview-kpi-val" style="background:rgba(14,165,233,0.3)"></div>
                </div>
            </div>

            <!-- Mock charts -->
            <div class="preview-charts">
                <div class="preview-chart">
                    <svg width="100%" height="100%" viewBox="0 0 300 80" preserveAspectRatio="none">
                        <polyline points="0,60 40,45 80,50 120,30 160,20 200,25 240,10 300,15"
                            fill="none" stroke="rgba(59,130,246,0.6)" stroke-width="2"/>
                        <polyline points="0,70 40,65 80,60 120,55 160,45 200,40 240,35 300,30"
                            fill="none" stroke="rgba(34,197,94,0.6)" stroke-width="2"/>
                        <polyline points="0,60 40,45 80,50 120,30 160,20 200,25 240,10 300,15"
                            fill="rgba(59,130,246,0.06)" stroke="none"/>
                    </svg>
                </div>
                <div class="preview-chart">
                    <div class="preview-bars">
                        <div class="preview-bar" style="height:40%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:60%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:45%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:70%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:55%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:80%;background:rgba(59,130,246,0.25)"></div>
                        <div class="preview-bar" style="height:65%;background:rgba(59,130,246,0.8)"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Overlay label -->
        <div style="text-align:center;margin-top:24px;">
            <a href="dashboard.html" class="btn-primary" style="display:inline-flex;">
                Open Live Dashboard →
            </a>
        </div>
    </div>
</section>

<!-- DATA SOURCES -->
<div class="sources">
    <div class="sources-inner">
        <div class="sources-label">Data sourced from leading market research firms</div>
        <div class="sources-badges">
            <div class="source-badge">Savills</div>
            <div class="source-badge">CBRE</div>
            <div class="source-badge">Colliers</div>
            <div class="source-badge">Knight Frank</div>
            <div class="source-badge">BNP Paribas RE</div>
            <div class="source-badge">Avison Young</div>
        </div>
    </div>
</div>

<!-- CTA -->
<section class="cta">
    <div class="cta-bg"></div>
    <div class="cta-content">
        <h2>Ready to explore the market?</h2>
        <p>Access AI-powered analytics across 8 Central London office submarkets. Live data, instant PDF reports, and Claude-generated research notes.</p>
        <a href="dashboard.html" class="btn-primary" style="display:inline-flex;font-size:16px;padding:16px 40px;">
            Launch Dashboard →
        </a>
    </div>
</section>

<!-- FOOTER -->
<footer class="footer">
    <div class="footer-left">
        Built by <strong>Dominic Mayne</strong> · West End Office Intelligence · © 2025
    </div>
    <div class="footer-right">
        <div class="footer-badge">Central London Analytics</div>
        <div class="footer-badge footer-badge-claude">✦ Powered by Claude</div>
    </div>
</footer>

</body>
</html>